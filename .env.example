# AfricaHirePlus - Variables d'environnement
# Copier vers .env et remplir les valeurs

# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (PostgreSQL)
POSTGRES_DB=africahireplus_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# Production
ALLOWED_HOSTS=api.africahireplus.com
CORS_ALLOWED_ORIGINS=https://app.africahireplus.com
CSRF_TRUSTED_ORIGINS=https://api.africahireplus.com
SECURE_SSL_REDIRECT=true

# AWS S3 (ou MinIO)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# ---------------------------------------------------------------------------
# Envoi d'emails (SMTP) – voir docs/CONFIGURATION_SMTP.md pour exemples (Gmail, OVH, SendGrid…)
# En dev sans ces variables : messages affichés dans le terminal (pas d'envoi réel).
# En prod : si EMAIL_HOST est défini, SMTP est activé automatiquement.
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@africahireplus.com
SERVER_EMAIL=noreply@africahireplus.com
# Tester après config : python manage.py send_test_email votre@email.com

# Logging
LOG_FILE=/var/log/africahireplus/django.log
