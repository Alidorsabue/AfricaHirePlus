# AfricaHirePlus - Variables d'environnement
# Copier vers .env et remplir les valeurs

# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (PostgreSQL)
POSTGRES_DB=africahireplus_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# Production
ALLOWED_HOSTS=api.africahireplus.com
CORS_ALLOWED_ORIGINS=https://app.africahireplus.com
CSRF_TRUSTED_ORIGINS=https://api.africahireplus.com
SECURE_SSL_REDIRECT=true

# AWS S3 (ou MinIO)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# ---------------------------------------------------------------------------
# Envoi d'e-mails (SMTP)
# - Sans EMAIL_HOST : backend console (dev) ou pas d’SMTP forcé selon settings.
# - Prod : si EMAIL_HOST est défini, prod active SMTP (voir config/settings/prod.py).
# - Doc détaillée : docs/CONFIGURATION_SMTP.md
# - Vérifier la config : python manage.py send_test_email --show-config
# - Test d’envoi      : python manage.py send_test_email votre@email.com
#
# Attention : le port 993 = IMAP (réception), pas SMTP. SMTP OVH en général :
#   587 + STARTTLS (TLS)  ou  465 + SSL implicite.
# ---------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=ssl0.ovh.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_HOST_USER=noreply@votredomaine.com
# EMAIL_HOST_PASSWORD=votre_mot_de_passe_ou_cle_application
# DEFAULT_FROM_EMAIL=noreply@votredomaine.com
# SERVER_EMAIL=noreply@votredomaine.com
# EMAIL_FROM_DISPLAY_NAME=AfricaHirePlus
# EMAIL_TIMEOUT=30

# Logging
LOG_FILE=/var/log/africahireplus/django.log
