# Optionnel : origine des fichiers /media/ si l’API est en relatif (/api/v1) mais les médias sur un autre host.
# VITE_MEDIA_ORIGIN=https://votre-backend.up.railway.app
#
# API Django : base avec /api/v1 en minuscules (pas /api/V1 — 404 Django). Sans slash final.
# En dev, optionnel : sans cette ligne → /api/v1 via proxy Vite.
# VITE_API_URL=https://votre-backend.up.railway.app/api/v1
# VITE_API_URL=http://127.0.0.1:8000/api/v1
